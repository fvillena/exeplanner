# Backend ejecutado directamente en Windows/macOS/Linux.
MONGODB_URI=mongodb://root:Gatos@127.0.0.1:27017/exeplanner?authSource=admin
MONGODB_DB=exeplanner
PORT=3001
CORS_ORIGIN=http://localhost:5173

# URL pública de la API usada por Vite.
VITE_API_URL=http://localhost:3001

# Si el backend se ejecuta dentro de un servicio Docker en la misma red,
# usa esta URI en lugar de la anterior:
# MONGODB_URI=mongodb://root:Gatos@mongo:27017/exeplanner?authSource=admin
